# ===========================================
# AI Spend Audit - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials to version control

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Gmail SMTP (for transactional emails)
# Get app password from: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
SKIP_EMAIL=false  # Set to 'true' to disable email sending during testing

# Frontend URLs
LOCAL_FRONTEND_URL=http://localhost:3000
PRODUCTION_FRONTEND_URL=https://your-production-domain.com
FRONTEND_URL=https://your-production-domain.com

# Gemini AI for AI-powered summaries
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Server port
PORT=8080